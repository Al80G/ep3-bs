<?php

$squareType = $this->option('subject.square.type');

if ($this->notBookableReason) {
    $reason = $this->notBookableReason;
} else {
    $reason = $this->t('This %s is already occupied.');
}

echo sprintf('<p><span class="red">' . $reason . '</span></p>', $squareType);

if ($this->bookings) {
    $ballmaschineBooked = false;
    foreach ($this->bookings as $booking) {
        if ($booking->getMeta('ballmaschine')) {
            $ballmaschineBooked = true;
            break;
        }
    }
    if ($ballmaschineBooked) {
        echo '<p class="gray"><em>' . $this->t('Ball machine') . ': ' . $this->t('booked') . '</em></p>';
    }
}

if ($this->user && $this->bookings) {
    foreach ($this->bookings as $bid => $booking) {
        $bookerUser = $booking->getExtra('user');
        $bookerName = $bookerUser ? $this->escapeHtml($bookerUser->need('alias')) : null;
        $names = $bookerName ? [$bookerName] : [];
        $raw = $booking->getMeta('player-names');
        if ($raw) {
            $players = @unserialize($raw);
            if ($players && is_array($players)) {
                foreach ($players as $entry) {
                    $name = isset($entry['value']) ? trim($entry['value']) : '';
                    if ($name !== '') {
                        $names[] = $this->escapeHtml($name);
                    }
                }
            }
        }
        if (!empty($names)) {
            echo '<p class="gray"><em>' . $this->t('Players') . ': ' . implode(', ', $names) . '</em></p>';
        }

        if ($bookerUser && $bookerUser->need('status') == 'placeholder') {
            if ($this->validator->isCancellable($booking)) {
                echo sprintf('<p><a href="%s" class="default-button squarebox-internal-link"><span class="symbolic symbolic-cross">%s</span></a></p>',
                    $this->url('square/booking/cancellation', [], ['query' => ['bid' => $bid]]),
                    $this->t('Cancel this booking'));
            }
        }
    }
}
